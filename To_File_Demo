# THE REAL DECISION LOGIC (identical to full version) 

 

def passes_naming_gate(fields): 

    # Gate A: were the fields the filename is based on read confidently enough? 

     

    conf = fields.get("field_confidence", {}) 

    for name in REQUIRED_NAMING_FIELDS: 

        if conf.get(name, 0) < NAMING_CONFIDENCE_THRESHOLD: 

            return False, f"low confidence on '{name}'" 

    return True, "" 

 

def find_project(fields): 

    # Gate B: try to tie this document to exactly one project. 

     

    # 1. Prefer an exact match on a printed project number 

    if fields.get("project_number"): 

        rows = query_projects_by_number(fields["project_number"]) 

        if len(rows) == 1: 

            return {"status": "one", "project":rows[0]} 

        if len(rows) > 1: 

            return {"status": "many", "reason": f"project #{fields['project_number']} matched {len(rows)} records"} 

    # 2. Otherwise try to match on the job-site address 

    if fields.get("project_address"): 

        rows = query_projects_by_address(fields["project_address"]) 

        if len(rows) == 1: 

            return {"status": "one", "project":rows[0]} 

        if len(rows) > 1: 

            return {"status": "many", "reason": f"address '{fields['project_address']}' matched {len(rows)} projects"} 

         

    return {"status": "none", "reason": "no project number or address match"} 

 

def build_filename(fields, project): 

    # Build a filename from the naming rules (placeholder rules here following billing naming conventions) 

    vendor = (fields.get("vendor_name") or "Unknown").replace(" ", " ") 

    doc_num = (fields.get("document_number") or "Unknown").replace(" ", "") 

    paid = " PAID" if fields.get("paid") else "" 

    doctype = fields.get("document_type") or "doc" 

    return f"{doctype}-{vendor} {doc_num}{paid}.pdf" 

 

# MAIN LOOP (near identical to full version) 

def main(): 

    print("Document Filing Bot - demo (no APIs)\n" + "=" * 52) 

     

    documents = list_to_file_documents() 

    results = {"filed":0, "review":0} 

     

    for document in documents: 

        print(f"\n[{document['name']}]") 

        fields = extract_fields(document) 

         

        # Gate A - naming confidence 

        ok_a, reason_a = passes_naming_gate(fields) 

        # Gate B - exactly one project match 

        project_result = find_project(fields) 

        ok_b = project_result["status"] == "one" 

         

        if ok_a and ok_b: 

            new_name = build_filename(fields, project_result["project"]) 

            move_and_rename(document, new_name, project_result["project"]["folder"]) 

            results["filed"] += 1 

        else: 

            reasons = [] 

            if not ok_a: 

                reasons.append(f"Gate A: {reason_a}") 

            if not ok_b: 

                reasons.append(f"Gate B: {project_result.get('reason', project_result['status'])}") 

            move_to_review(document, reasons) 

            results["review"] += 1 

 

    print("\n" + "=" * 52) 

    print(f"Summary:  {results['filed']} filed automatically, {results['review']} sent to Review.") 

    print("(In the real system, 'Review' means a human gives it a quick look.)") 

 

 

if __name__ == "__main__": 

    main() 

                 

     

     

 